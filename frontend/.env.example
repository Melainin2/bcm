# URL du backend FastAPI.
#
# - Déploiement Render en SERVICE UNIQUE (backend sert le frontend) :
#   laissez cette variable VIDE -> les appels /api/* pointent vers le même domaine.
#     VITE_API_BASE_URL=
#
# - Dev local (frontend `npm run dev` sur :5173, backend séparé) :
#   indiquez l'URL du backend, ex. :
#     VITE_API_BASE_URL=http://localhost:8001
VITE_API_BASE_URL=
