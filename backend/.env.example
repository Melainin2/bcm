# =====================================================================
# DBA-GPT — configuration backend (copiez ce fichier vers .env)
# ⚠️  NE JAMAIS committer votre vraie clé API. Voir .gitignore.
# =====================================================================

# --- Claude / Anthropic ------------------------------------------------
ANTHROPIC_API_KEY=your_api_key_here
# Modèle Claude par défaut si le frontend n'en envoie aucun.
CLAUDE_MODEL=claude-sonnet-4-6
# Modèles sélectionnables depuis l'interface (séparés par des virgules).
# Le backend refuse (HTTP 400) tout modèle absent de cette liste.
AVAILABLE_CLAUDE_MODELS=claude-sonnet-4-6,claude-sonnet-5
MAX_TOKENS=2000

# --- RAG : chemins & collection ---------------------------------------
CHROMA_PATH=../chroma_db
DATA_PATH=../data
COLLECTION_NAME=dba_docs

# --- Embeddings --------------------------------------------------------
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# --- Retrieval / reranking --------------------------------------------
TOP_K=5
RETRIEVER_TOP_K=20
RERANK_TOP_K=5
USE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-base

# --- Seuils de similarité / confiance ---------------------------------
SIMILARITY_THRESHOLD=0.70
HIGH_CONFIDENCE_THRESHOLD=0.71
MEDIUM_CONFIDENCE_THRESHOLD=0.52

# --- Chunking ----------------------------------------------------------
CHUNK_SIZE=700
CHUNK_OVERLAP=150

# --- Normalisation requête --------------------------------------------
QUERY_PREPROCESS=true
FUZZY_THRESHOLD=82

# --- API ---------------------------------------------------------------
# Origines frontend autorisées (CORS), séparées par des virgules.
# En production, ajoutez l'URL Vercel de votre frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
